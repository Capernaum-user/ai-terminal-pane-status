// =====================================================================
//  Zellij 설정 — AI 분할 워크스페이스 파일럿
//  생성: 2026-06-28
//  Zellij 0.44+ 네이티브 Windows. 각 패널 셸로 PowerShell 7(pwsh) 사용.
// =====================================================================

// 각 패널의 기본 셸 = 네이티브 Windows PowerShell 7 (WSL 아님)
default_shell "pwsh.exe"

// 패널마다 제목 프레임 표시  ← 이게 사용자가 원했던 "소제목줄"
pane_frames true

// Windows 클립보드 연동
copy_command "clip.exe"

// 마우스 사용 (Shift 누르면 일시적으로 터미널 기본 선택 동작)
mouse_mode true
